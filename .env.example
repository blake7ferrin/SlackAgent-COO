# Copy to .env for local dev, or use Doppler: `doppler run -- uvicorn main:app ...`
# (see README). Environment variables always win over this file for pydantic-settings.
# Set LOAD_DOTENV=0 to ignore this file entirely (Doppler-only / production).

# Slack (Bolt / Events API)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# xAI Grok (OpenAI-compatible client)
XAI_API_KEY=xai-your-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest

# Existing report / business backend (tools call into this)
BACKEND_BASE_URL=https://your-backend.example.com
# Set true in production to call the real report API (see app/tools/implementations.py for path/payload)
BACKEND_GENERATE_REPORT_ENABLED=false

# Timeouts (seconds)
GROK_REQUEST_TIMEOUT_SECONDS=120
BACKEND_HTTP_TIMEOUT_SECONDS=60
ORCHESTRATION_TIMEOUT_SECONDS=180

# Server
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
